---
import BlogLayout from '@/layouts/BlogLayout.astro';
import { render, type CollectionEntry } from 'astro:content';
import { calculateReadingTime } from '@/lib/utils';
import { getBlogPosts } from '@/lib/strapi';
import type { BlogEntry } from '@/lib/blog';
import InlineModelCard from '@/components/mdx/InlineModelCard.astro';
import OptimizedImage from '@components/common/OptimizedImage.astro';

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  return posts.map((post: BlogEntry) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: BlogEntry;
}

const { post } = Astro.props;

const fromStrapi = post.__fromStrapi === true;

type BlogRenderResult = Awaited<ReturnType<typeof render>>;
let Content: BlogRenderResult['Content'] | null = null;
let headings: BlogRenderResult['headings'] = [];

if (!fromStrapi) {
  const renderResult = await render(post as CollectionEntry<'blog'>);
  Content = renderResult.Content;
  headings = renderResult.headings;
}

/** Strapi HTML is treated as trusted CMS output; local posts use MDX/Markdown via `render`. */
const strapiHtml = fromStrapi && post.body ? post.body : '';

const readingContent = fromStrapi ? strapiHtml.replaceAll(/<[^>]+>/g, ' ') : post.body || '';

interface RelatedPostWithScore {
  post: BlogEntry;
  sharedTags: number;
}

const allPosts = await getBlogPosts();

const relatedPosts: BlogEntry[] = allPosts
  .filter((p: BlogEntry) => p.id !== post.id)
  .map(
    (p: BlogEntry): RelatedPostWithScore => ({
      post: p,
      sharedTags: (p.data.tags ?? []).filter((tag: string) => (post.data.tags ?? []).includes(tag))
        .length,
    })
  )
  .filter((p: RelatedPostWithScore) => p.sharedTags > 0)
  .sort((a: RelatedPostWithScore, b: RelatedPostWithScore) => {
    if (b.sharedTags !== a.sharedTags) {
      return b.sharedTags - a.sharedTags;
    }
    return b.post.data.publishedDate.getTime() - a.post.data.publishedDate.getTime();
  })
  .slice(0, 3)
  .map((p: RelatedPostWithScore) => p.post);
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  publishedDate={post.data.publishedDate}
  author={post.data.author}
  image={post.data.image}
  tags={post.data.tags}
  content={readingContent}
  headings={headings}
>
  <div slot="content">
    {
      Content ? (
        <Content components={{ InlineModelCard }} />
      ) : fromStrapi ? (
        <div class="prose prose-neutral dark:prose-invert max-w-none" set:html={strapiHtml} />
      ) : (
        <p class="text-text-muted">This article has no content.</p>
      )
    }
  </div>

  <!-- Related Posts -->
  {
    relatedPosts.length > 0 && (
      <aside class="mt-16 pt-12 border-t border-border">
        <h2 class="text-2xl font-bold text-text mb-8">Related Posts</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedPosts.map((relatedPost) => (
            <a href={`/blog/${relatedPost.id}`} class="group block h-full">
              <article class="h-full rounded-xl overflow-hidden border border-border hover:border-primary/50 hover:shadow-lg transition-all bg-surface/50 flex flex-col">
                <div class="h-48 w-full bg-surface relative overflow-hidden">
                  {relatedPost.data.image ? (
                    <OptimizedImage
                      src={relatedPost.data.image}
                      alt={relatedPost.data.title}
                      width={1200}
                      height={800}
                      class="w-full h-full object-cover"
                      loading="lazy"
                    />
                  ) : (
                    <div class="w-full h-full bg-primary/5 flex items-center justify-center" />
                  )}
                </div>
                <div class="p-6 flex-1 flex flex-col">
                  {relatedPost.data.tags && relatedPost.data.tags.length > 0 && (
                    <div class="text-xs font-medium text-primary mb-3">
                      {relatedPost.data.tags[0]}
                    </div>
                  )}
                  <h3 class="font-bold text-lg text-text group-hover:text-primary transition-colors line-clamp-2 mb-2">
                    {relatedPost.data.title}
                  </h3>
                  <p class="text-sm text-text-muted mt-auto line-clamp-2 mb-4">
                    {relatedPost.data.description}
                  </p>
                  <div class="flex items-center text-xs text-text-muted font-medium pt-4 border-t border-border/50">
                    {relatedPost.data.publishedDate.toLocaleDateString('en-US', {
                      month: 'short',
                      day: 'numeric',
                      year: 'numeric',
                    })}
                    <span class="mx-2">·</span>
                    {calculateReadingTime(
                      relatedPost.__fromStrapi
                        ? (relatedPost.body || '').replaceAll(/<[^>]+>/g, ' ')
                        : relatedPost.body || ''
                    )}{' '}
                    min read
                  </div>
                </div>
              </article>
            </a>
          ))}
        </div>
      </aside>
    )
  }
</BlogLayout>
