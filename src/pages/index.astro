---
import { getCollection, type CollectionEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import HomeDashboard from '@sections/marketing/HomeDashboard.astro';
import CodingIndex from '@sections/marketing/CodingIndex.astro';
import Newsletter from '@sections/marketing/Newsletter.astro';
import { siteConfig } from '@/config';
import highlightsData from '@/data/highlights.json';

type BlogPost = CollectionEntry<'blog'>;

const posts = await getCollection('blog', ({ data }: { data: BlogPost['data'] }) => !data.draft);
const latestPosts = [...posts]
  .sort(
    (a: BlogPost, b: BlogPost) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
  )
  .slice(0, 3);

const bentoItems = [
  {
    title: 'Top 10 Models',
    description: 'The overall best large language models ranked by aggregate benchmark scores.',
    icon: 'lucide:trophy',
    size: 'large' as const,
    accent: 'primary' as const,
    href: '/leaderboards/top-10',
  },
  {
    title: 'Best for Coding',
    description: 'Top models for programming, software engineering, and solving SWE-bench tasks.',
    icon: 'lucide:code',
    accent: 'blue' as const,
    href: '/leaderboards/coding',
  },
  {
    title: 'Cost-Effective',
    description: 'High-performing models that offer the best bang for your buck.',
    icon: 'lucide:piggy-bank',
    accent: 'green' as const,
    href: '/leaderboards/cost-effective',
  },
  {
    title: 'Local & Offline',
    description: 'Open-weight models you can run completely offline on your own hardware.',
    icon: 'lucide:download',
    size: 'medium' as const,
    accent: 'purple' as const,
    href: '/leaderboards/offline',
  },
];

const highlights = highlightsData as {
  id: string;
  title: string;
  subtitle: string;
  colorDot: string;
  chartColor: string;
  labels: string[];
  data: number[];
}[];
---

<MarketingLayout
  title={`${siteConfig.name} - Compare & Discover the Best AI Models`}
  description="Discover the perfect AI model for your workflow. Compare 300+ LLMs by pricing, context window, and benchmarks. Backed by deep-dive reviews and tutorials."
>
  <HomeDashboard highlights={highlights} bentoItems={bentoItems} latestPosts={latestPosts} />

  <CodingIndex />

  <!-- CTA + Newsletter: Integrated design -->
  <section class="relative py-20 sm:py-28 bg-surface/30 dark:bg-surface/10 border-b border-border/50 overflow-hidden">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,var(--color-primary),transparent)] opacity-[0.03] dark:opacity-[0.05]"></div>
    
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div>
          <h2 class="text-3xl sm:text-4xl font-semibold text-text tracking-tight text-balance">
            Ready to find your next AI model?
          </h2>
          <p class="mt-6 text-lg text-text-muted leading-relaxed">
            Browse our comprehensive directory of 300+ LLMs with up-to-date pricing, 
            context windows, and verified benchmark scores.
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href="/leaderboards/top-50"
              class="inline-flex items-center justify-center px-8 py-4 rounded-2xl bg-primary text-white font-bold text-sm hover:bg-primary-dark transition-all shadow-xl shadow-primary/20"
            >
              View all models
            </a>
            <a
              href="/blog"
              class="inline-flex items-center justify-center px-8 py-4 rounded-2xl border border-border bg-background text-text font-bold text-sm hover:bg-surface transition-all"
            >
              Read the blog
            </a>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-tr from-primary/10 to-transparent blur-2xl opacity-50"></div>
          <div class="relative rounded-3xl border border-border/60 bg-background shadow-2xl shadow-black/5 overflow-hidden">
            <Newsletter variant="compact" background="none" title="Join the newsletter" description="Get weekly analysis of new models and benchmark updates delivered to your inbox." />
          </div>
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
