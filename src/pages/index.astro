---
import { getCollection, type CollectionEntry } from 'astro:content';
import MarketingLayout from '@/layouts/MarketingLayout.astro';
import HomeDashboard from '@sections/marketing/HomeDashboard.astro';
import Newsletter from '@sections/marketing/Newsletter.astro';
import { siteConfig } from '@/config';
import highlightsData from '@/data/highlights.json';

type BlogPost = CollectionEntry<'blog'>;

const posts = await getCollection('blog', ({ data }: { data: BlogPost['data'] }) => !data.draft);
const latestPosts = [...posts]
  .sort(
    (a: BlogPost, b: BlogPost) => b.data.publishedDate.getTime() - a.data.publishedDate.getTime()
  )
  .slice(0, 3);

const bentoItems = [
  {
    title: 'Top 10 Models',
    description: 'The overall best large language models ranked by aggregate benchmark scores.',
    icon: 'lucide:trophy',
    size: 'large' as const,
    accent: 'primary' as const,
    href: '/leaderboards/top-10',
  },
  {
    title: 'Best for Coding',
    description: 'Top models for programming, software engineering, and solving SWE-bench tasks.',
    icon: 'lucide:code',
    accent: 'blue' as const,
    href: '/leaderboards/coding',
  },
  {
    title: 'Cost-Effective',
    description: 'High-performing models that offer the best bang for your buck.',
    icon: 'lucide:piggy-bank',
    accent: 'green' as const,
    href: '/leaderboards/cost-effective',
  },
  {
    title: 'Local & Offline',
    description: 'Open-weight models you can run completely offline on your own hardware.',
    icon: 'lucide:download',
    size: 'medium' as const,
    accent: 'purple' as const,
    href: '/leaderboards/offline',
  },
];

const highlights = highlightsData as {
  id: string;
  title: string;
  subtitle: string;
  colorDot: string;
  chartColor: string;
  labels: string[];
  data: number[];
}[];
---

<MarketingLayout
  title={`${siteConfig.name} - Compare & Discover the Best AI Models`}
  description="Discover the perfect AI model for your workflow. Compare 300+ LLMs by pricing, context window, and benchmarks. Backed by deep-dive reviews and tutorials."
>
  <HomeDashboard highlights={highlights} bentoItems={bentoItems} latestPosts={latestPosts} />

  <!-- Lavender band: CTA + newsletter (inspired by report-style footers) -->
  <section
    class="relative py-16 sm:py-20 bg-[oklch(0.70_0.09_292)] dark:bg-[oklch(0.22_0.06_290)] text-white overflow-hidden"
  >
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_30%_0%,rgba(255,255,255,0.15),transparent_50%)]"
    >
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-2xl mx-auto">
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">
          Ready to find your next AI model?
        </h2>
        <p class="mt-3 text-white/85 text-sm sm:text-base leading-relaxed">
          Browse the full directory—pricing, context windows, and benchmarks in one place.
        </p>
        <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
          <a
            href="/leaderboards/top-50"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl bg-white text-violet-950 font-semibold text-sm hover:bg-white/95 transition-colors shadow-lg shadow-black/10"
          >
            View all models
          </a>
          <a
            href="/blog"
            class="inline-flex items-center justify-center px-6 py-3 rounded-xl border border-white/35 text-white font-semibold text-sm hover:bg-white/10 transition-colors"
          >
            Read the blog
          </a>
        </div>
      </div>

      <div
        class="mt-14 max-w-xl mx-auto rounded-2xl bg-background text-text p-1 shadow-2xl shadow-black/20 border border-white/25"
      >
        <div class="rounded-xl bg-surface/80 dark:bg-surface/50 px-4 py-6 sm:px-6">
          <Newsletter variant="compact" background="default" />
        </div>
      </div>
    </div>
  </section>
</MarketingLayout>
