---
/**
 * Marketing chart card — wraps Chart.js with metadata from `src/data/charts/*.json`.
 */
import { Icon } from 'astro-icon/components';
import Chart from '@dashboard-ui/Chart.astro';
import type { ExtractedChartBundle } from '@/lib/chart-datasets';
import { CHART_DATA_SOURCE_PATH } from '@/lib/chart-datasets';

interface Props {
  bundle: ExtractedChartBundle;
}

const { bundle } = Astro.props;
const { presentation, navigation, chart, meta, sourceFile, updatedAt } = bundle;
const type = presentation.chartType;
const updatedLabel = new Date(updatedAt).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});
---

<div
  class="group relative flex flex-col h-full rounded-2xl border border-border/70 bg-gradient-to-b from-surface to-surface/80 dark:from-surface/50 dark:to-surface/30 shadow-[0_1px_0_rgba(0,0,0,0.06)] dark:shadow-none overflow-hidden ring-1 ring-black/[0.03] dark:ring-white/[0.06] transition-shadow hover:shadow-md hover:ring-primary/10"
>
  <div
    class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-primary/25 to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"
  >
  </div>

  <div
    class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3 px-5 pt-5 pb-1 border-b border-border/40"
  >
    <div class="min-w-0">
      <h3 class="text-[15px] font-semibold text-text leading-snug tracking-tight">
        {presentation.title}
      </h3>
      <p class="text-xs text-text-muted mt-1.5 leading-relaxed max-w-prose">
        {presentation.subtitle}
      </p>
      <p class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-[10px] uppercase tracking-wider text-text-muted/80">
        <span class="inline-flex items-center gap-1">
          <Icon name="lucide:database" class="w-3 h-3" />
          {sourceFile}
        </span>
        <span class="tabular-nums">Updated {updatedLabel}</span>
      </p>
    </div>
    <a
      href={navigation.href}
      class="inline-flex items-center gap-1.5 shrink-0 text-xs font-semibold text-primary hover:text-primary-dark transition-colors rounded-lg px-2 py-1 -mr-1 hover:bg-primary/5"
    >
      {navigation.label}
      <Icon name="lucide:arrow-up-right" class="w-3.5 h-3.5" />
    </a>
  </div>

  <div class="px-2 sm:px-3 pb-1 pt-2 flex-1 min-h-0">
    <Chart
      type={type}
      data={chart}
      meta={meta}
      height={presentation.height}
      ariaLabel={`${presentation.title}. ${presentation.subtitle}`}
    />
  </div>

  <div
    class="px-5 py-3 border-t border-border/40 bg-[oklch(0.98_0.01_264)]/80 dark:bg-background/40 text-[10px] text-text-muted flex flex-wrap items-center justify-between gap-2"
  >
    <span>
      Derived from <code class="px-1 py-0.5 rounded bg-surface border border-border/50 text-[9px]">{CHART_DATA_SOURCE_PATH}</code>
    </span>
    <span class="opacity-80">Hover bars or points for full model details</span>
  </div>
</div>
