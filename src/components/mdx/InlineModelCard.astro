---
import { getModelsByCategory } from '@/services/models';
import type { AiModel } from '@/types/database';
import { Icon } from 'astro-icon/components';

interface Props {
  id: string; // the model id, e.g. "openai-gpt-4o"
}

const { id } = Astro.props;

// We fetch all models from the base view or top-50 view
const allModels = await getModelsByCategory('top-50');
// Find the exact model - prioritize id match, then exact model name match
const model = allModels.find((m: AiModel) => {
  if (m.id && id && m.id.toString() === id.toString()) {
    return true;
  }
  if (m.model && id && m.model.toLowerCase() === id.toLowerCase()) {
    return true;
  }
  return false;
});
---

{
  model ? (
    <div class="my-6 rounded-lg border border-border bg-surface p-4 shadow-sm not-prose">
      <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
          <h4 class="text-lg text-text font-bold flex items-center gap-2">
            <Icon name="lucide:bot" class="w-5 h-5 text-primary" />
            {model.company} {model.model}
          </h4>
          <div class="text-sm text-text-muted mt-1">
            Context Window:{' '}
            <span class="font-medium text-text">
              {model.context_window
                ? isNaN(Number(model.context_window))
                  ? model.context_window
                  : new Intl.NumberFormat('en-US').format(Number(model.context_window))
                : 'Unknown'}{' '}
              tokens
            </span>
          </div>
        </div>
        <div class="flex flex-wrap items-center gap-3">
          <div class="px-3 py-1.5 rounded-md bg-muted text-xs font-semibold text-text">
            GPQA:{' '}
            {model.gpqa != null
              ? (model.gpqa > 1 ? model.gpqa.toFixed(1) : (model.gpqa * 100).toFixed(1)) + '%'
              : 'N/A'}
          </div>
          <div class="px-3 py-1.5 rounded-md bg-muted text-xs font-semibold text-text">
            SWE-bench:{' '}
            {model.swe_bench != null
              ? (model.swe_bench > 1
                  ? model.swe_bench.toFixed(1)
                  : (model.swe_bench * 100).toFixed(1)) + '%'
              : 'N/A'}
          </div>
          <a
            href={`/leaderboards/top-50`}
            class="px-3 py-1.5 rounded-md bg-primary text-white text-xs font-medium hover:opacity-90 inline-flex items-center"
          >
            Compare <Icon name="lucide:arrow-right" class="w-3 h-3 ml-1" />
          </a>
        </div>
      </div>

      <div class="mt-4 pt-4 border-t border-border grid grid-cols-2 text-sm">
        <div>
          <span class="text-text-muted">Input Cost:</span>
          <span class="ml-2 font-medium text-text">
            {model.input_price_per_million != null ? `$${model.input_price_per_million}` : 'N/A'} / 1M
          </span>
        </div>
        <div>
          <span class="text-text-muted">Output Cost:</span>
          <span class="ml-2 font-medium text-text">
            {model.output_price_per_million != null ? `$${model.output_price_per_million}` : 'N/A'} / 1M
          </span>
        </div>
      </div>
    </div>
  ) : (
    <div class="p-4 bg-red-100 text-red-800 rounded-md my-4 not-prose">
      Inline Model Card: Could not find model "{id}" in database.
    </div>
  )
}
